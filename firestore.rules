rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == 'tapadarhribhu@gmail.com' || request.auth.token.phone_number == '+911234567890');
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId 
        && (request.resource.data.role == 'user' || (request.resource.data.role == 'admin' && (request.auth.token.email == 'tapadarhribhu@gmail.com' || request.auth.token.phone_number == '+911234567890')));
      allow update: if (isOwner(userId) && (
        request.resource.data.role == resource.data.get('role', request.resource.data.role) &&
        request.resource.data.phoneNumber == resource.data.get('phoneNumber', request.resource.data.phoneNumber) &&
        request.resource.data.clientId == resource.data.get('clientId', request.resource.data.clientId) &&
        request.resource.data.referralCode == resource.data.get('referralCode', request.resource.data.referralCode) &&
        request.resource.data.createdAt == resource.data.get('createdAt', request.resource.data.createdAt)
      )) || (
        // Allow another authenticated user to update referrer stats when applying a referral
        isAuthenticated() && 
        request.resource.data.get('referralCount', 0) == resource.data.get('referralCount', 0) + 1 &&
        request.resource.data.get('totalReferralRewards', 0) == resource.data.get('totalReferralRewards', 0) + 10 &&
        request.resource.data.get('seeds', 0) == resource.data.get('seeds', 0) + 10 &&
        request.resource.data.get('role', 'user') == resource.data.get('role', 'user') &&
        request.resource.data.get('clientId', '') == resource.data.get('clientId', '') &&
        request.resource.data.get('referralCode', '') == resource.data.get('referralCode', '')
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // Referrals Collection
    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (resource.data.referrerUid == request.auth.uid || resource.data.referredUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.referredUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
